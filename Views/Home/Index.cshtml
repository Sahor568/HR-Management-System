@{
    ViewData["Title"] = "HR Management System - Login";
}

<style>
    .login-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
    }

    .login-card {
        background: var(--white);
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
        max-width: 450px;
        width: 100%;
        padding: 3rem;
    }

    .login-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .login-logo {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 2rem;
        margin: 0 auto 1rem;
    }

    .login-title {
        font-size: 1.8rem;
        font-weight: 700;
        margin: 0 0 0.5rem 0;
        color: var(--text-dark);
    }

    .login-subtitle {
        color: var(--text-light);
        margin: 0;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-group label {
        display: block;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: var(--text-dark);
    }

    .form-group input {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

    .form-group input:focus {
        outline: none;
        border-color: var(--primary-color);
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
    }

    .remember-forgot {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        font-size: 0.9rem;
    }

    .remember-forgot a {
        color: var(--primary-color);
        text-decoration: none;
    }

    .remember-forgot a:hover {
        text-decoration: underline;
    }

    .login-btn {
        width: 100%;
        padding: 0.75rem 1.5rem;
        background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .login-btn:hover {
        box-shadow: 0 4px 12px rgba(37, 99, 235, 0.4);
        transform: translateY(-2px);
    }

    .login-btn:disabled {
        opacity: 0.7;
        cursor: not-allowed;
        transform: none;
    }

    .signup-link {
        text-align: center;
        margin-top: 1.5rem;
        font-size: 0.9rem;
        color: var(--text-light);
    }

    .signup-link a {
        color: var(--primary-color);
        text-decoration: none;
        font-weight: 600;
    }

    .signup-link a:hover {
        text-decoration: underline;
    }

    .demo-notice {
        background: var(--light-bg);
        border-radius: 8px;
        padding: 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.85rem;
        color: var(--text-light);
    }

    .demo-notice strong {
        color: var(--text-dark);
        display: block;
        margin-bottom: 0.5rem;
    }

    .login-error {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #dc2626;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        margin-bottom: 1rem;
        font-size: 0.9rem;
        display: none;
    }
</style>

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <div class="login-logo">
                <i class="fas fa-users"></i>
            </div>
            <h1 class="login-title">HR System</h1>
            <p class="login-subtitle">Advanced HR Management Platform</p>
        </div>

        <div class="demo-notice">
            <strong>Demo Credentials:</strong>
            Admin: admin@hrsystem.com / 11111111<br>
            HR: hr@hrsystem.com / Hr@123
        </div>

        <div class="login-error" id="loginError"></div>

        <form id="loginForm">
            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="your@company.com" required>
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="Enter your password" required>
            </div>

            <div class="remember-forgot">
                <label style="display: flex; align-items: center; gap: 0.5rem; margin: 0;">
                    <input type="checkbox" name="rememberMe" style="width: auto;">
                    Remember me
                </label>
                <a href="#">Forgot Password?</a>
            </div>

            <button type="submit" class="login-btn" id="loginBtn">
                <i class="fas fa-sign-in-alt" style="margin-right: 0.5rem;"></i> Sign In
            </button>
        </form>

        <div class="signup-link">
            Don't have an account? Contact your administrator
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // If already authenticated, redirect to dashboard
            if (isAuthenticated()) {
                window.location.href = '/Home/Dashboard';
                return;
            }

            $('#loginForm').on('submit', async function(e) {
                e.preventDefault();
                
                const email = $('#email').val().trim();
                const password = $('#password').val();
                const $btn = $('#loginBtn');
                const $error = $('#loginError');
                
                if (!email || !password) {
                    $error.text('Email and password are required').show();
                    return;
                }
                
                $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin" style="margin-right: 0.5rem;"></i> Signing in...');
                $error.hide();
                
                try {
                    // Step 1: Call API login to get JWT token
                    const apiResponse = await fetch('/api/Login/login', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email, password })
                    });
                    
                    if (!apiResponse.ok) {
                        const errorText = await apiResponse.text();
                        throw new Error(errorText || 'Invalid email or password');
                    }
                    
                    const loginData = await apiResponse.json();
                    
                    // Store JWT token and user info in localStorage
                    localStorage.setItem('auth_token', loginData.token);
                    localStorage.setItem('user_email', loginData.email);
                    localStorage.setItem('user_role', loginData.role);
                    localStorage.setItem('user_id', loginData.id);
                    localStorage.setItem('user_name', loginData.email);
                    
                    // Step 2: Also create cookie authentication via MVC
                    const formData = new FormData();
                    formData.append('email', email);
                    formData.append('password', password);
                    
                    await fetch('/Home/Login', {
                        method: 'POST',
                        body: formData,
                        credentials: 'include'
                    });
                    
                    // Step 3: Get employee record if exists
                    try {
                        const profileResponse = await fetch('/api/Employees/my-profile', {
                            headers: { 'Authorization': `Bearer ${loginData.token}` }
                        });
                        if (profileResponse.ok) {
                            const profileData = await profileResponse.json();
                            if (profileData.id) {
                                localStorage.setItem('user_employeeId', profileData.id);
                                localStorage.setItem('user_name', profileData.fullName || loginData.email);
                            }
                        }
                    } catch (e) {
                        // Profile fetch failed, continue anyway
                    }
                    
                    // Redirect to dashboard
                    window.location.href = '/Home/Dashboard';
                    
                } catch (error) {
                    $error.text(error.message || 'Login failed. Please try again.').show();
                    $btn.prop('disabled', false).html('<i class="fas fa-sign-in-alt" style="margin-right: 0.5rem;"></i> Sign In');
                }
            });
        });
    </script>
}
