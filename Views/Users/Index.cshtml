    <div class="user-card-grid">
        <div class="user-card">
            <div class="user-card-avatar" style="background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);">AD</div>
            <h5>Admin User</h5>
            <p>admin@company.com</p>
            <div style="margin: 1rem 0;">
                <span class="role-badge role-admin">Admin</span>
            </div>
            <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
                <a href="#" class="btn btn-sm btn-outline-primary w-100">Edit</a>
                <button class="btn btn-sm btn-outline-danger w-100">Deactivate</button>
            </div>
        </div>

        <div class="user-card">
            <div class="user-card-avatar" style="background: linear-gradient(135deg, #10b981 0%, #059e0a 100%);">SM</div>
            <h5>Sarah Miller</h5>
            <p>sarah@company.com</p>
            <div style="margin: 1rem 0;">
                <span class="role-badge role-hr">HR</span>
            </div>
            <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
