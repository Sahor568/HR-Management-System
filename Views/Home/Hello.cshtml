@{
    ViewData["Title"] = "Hello";
}

<style>
    :root {
        --white: #ffffff;
        --text-dark: #1f2937;
        --text-light: #6b7280;
        --primary-color: #2563eb;
        --border-color: #d1d5db;
    }
    
    .dashboard-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .welcome-card {
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        max-width: 800px;
        width: 100%;
        padding: 3rem;
        text-align: center;
    }

    .welcome-header {
        margin-bottom: 2rem;
    }

    .welcome-logo {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 2.5rem;
        margin: 0 auto 1.5rem;
    }

    .welcome-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin: 0 0 1rem 0;
        color: var(--text-dark);
    }

    .welcome-subtitle {
        font-size: 1.2rem;
        color: var(--text-light);
        margin: 0 0 2rem 0;
        line-height: 1.6;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
        margin: 2rem 0;
    }

    .feature-card {
        background: #f8fafc;
        border-radius: 12px;
        padding: 1.5rem;
        text-align: left;
        border: 1px solid var(--border-color);
        transition: all 0.3s ease;
    }

        .feature-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
        }

    .feature-icon {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.5rem;
        margin-bottom: 1rem;
    }

    .feature-title {
        font-size: 1.2rem;
        font-weight: 600;
        margin: 0 0 0.5rem 0;
        color: var(--text-dark);
    }

    .feature-description {
        color: var(--text-light);
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.5;
    }

    .action-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 2rem;
        flex-wrap: wrap;
    }

    .btn-primary-custom {
        background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 0.75rem 2rem;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

        .btn-primary-custom:hover {
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.4);
            transform: translateY(-2px);
            color: white;
            text-decoration: none;
        }

    .btn-outline-custom {
        background: white;
        color: var(--primary-color);
        border: 2px solid var(--primary-color);
        border-radius: 8px;
        padding: 0.75rem 2rem;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

        .btn-outline-custom:hover {
            background: var(--primary-color);
            color: white;
            text-decoration: none;
        }

    .notice {
        background: #f0f9ff;
        border-radius: 8px;
        padding: 1rem;
        margin-top: 2rem;
        font-size: 0.9rem;
        color: #0369a1;
        border-left: 4px solid #0ea5e9;
    }
</style>

<div class="dashboard-container">
    <div class="welcome-card">
        <div class="welcome-header">
            <div class="welcome-logo">
                <i class="fas fa-users"></i>
            </div>
            <h1 class="welcome-title">HR Management System</h1>
            <p class="welcome-subtitle">
                Welcome to the HR Management Platform. All role-based restrictions have been removed.
                Anyone can view any page without authentication or authorization.
            </p>
        </div>

        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fas fa-clipboard-list"></i>
                </div>
                <h3 class="feature-title">System Logs</h3>
                <p class="feature-description">
                    View and manage system activity logs. Monitor all actions and events in the HR system.
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fas fa-user-tie"></i>
                </div>
                <h3 class="feature-title">User Management</h3>
                <p class="feature-description">
                    Manage user accounts, roles, and permissions across the organization.
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fas fa-chart-line"></i>
                </div>
                <h3 class="feature-title">Dashboard Analytics</h3>
                <p class="feature-description">
                    Access comprehensive analytics and reports on HR metrics and performance.
                </p>
            </div>
        </div>

        <div class="action-buttons">
            <a href="@Url.Action("Index", "Logs")" class="btn-primary-custom">
                <i class="fas fa-clipboard-list"></i> View System Logs
            </a>
            <a href="@Url.Action("Privacy", "Home")" class="btn-outline-custom">
                <i class="fas fa-shield-alt"></i> Privacy Policy
            </a>
            <a href="@Url.Action("Settings", "Home")" class="btn-outline-custom">
                <i class="fas fa-cog"></i> Settings
            </a>
        </div>

        <div class="notice">
            <strong>Note:</strong> All authorization and authentication have been temporarily disabled.
            JWT authentication has been removed. Anyone can access any page without login.
        </div>
    </div>
</div>
