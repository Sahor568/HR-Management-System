            </div>
        </div>

        <div class="user-row">
            <div class="user-info">
                <div class="user-avatar" style="width: 40px; height: 40px; background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);">JD</div>
                <div class="user-details">
                    <h6>John Doe</h6>
                    <p>john@company.com</p>
                </div>
            </div>
            <div style="width: 120px;">
                <span class="role-badge role-employee">Employee</span>
            </div>
            <div style="width: 100px;">
                <span class="status-badge status-active"></span> Active
            </div>
            <div class="user-actions">
                <a href="#" class="btn btn-sm btn-outline-primary">Edit</a>
                <button class="btn btn-sm btn-outline-danger">Deactivate</button>
            </div>
        </div>

        <div class="user-row">
            <div class="user-info">
                <div class="user-avatar" style="width: 40px; height: 40px; background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);">MB</div>
                <div class="user-details">
                    <h6>Mike Brown</h6>
                    <p>mike@company.com</p>
                </div>
            </div>
            <div style="width: 120px;">
                <span class="role-badge role-employee">Employee</span>
            </div>
            <div style="width: 100px;">
                <span class="status-badge status-active"></span> Active
            </div>
            <div class="user-actions">
                <a href="#" class="btn btn-sm btn-outline-primary">Edit</a>
                <button class="btn btn-sm btn-outline-danger">Deactivate</button>
            </div>
        </div>

        <div class="user-row">
            <div class="user-info">
                <div class="user-avatar" style="width: 40px; height: 40px; background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);">EJ</div>
                <div class="user-details">
                    <h6>Emma Johnson</h6>
                    <p>emma@company.com</p>
                </div>
            </div>
            <div style="width: 120px;">
                <span class="role-badge role-employee">Employee</span>
            </div>
            <div style="width: 100px;">
                <span class="status-badge status-inactive"></span> Inactive
            </div>
            <div class="user-actions">
                <a href="#" class="btn btn-sm btn-outline-primary">Edit</a>
                <button class="btn btn-sm btn-outline-success">Activate</button>
            </div>
        </div>
    </div>
</div>

