@model IEnumerable<Management.Models.Department>

@{
    ViewData["Title"] = "Departments Management";
}

<style>
    .department-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
        margin-top: 2rem;
    }

    .department-card {
        background: var(--white);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .department-card:hover {
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
        border-color: var(--primary-color);
        transform: translateY(-4px);
    }

    .department-header {
        background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
        color: white;
        padding: 2rem;
        text-align: center;
    }

    .department-icon {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
    }

    .department-name {
        font-size: 1.3rem;
        font-weight: 700;
        margin: 0;
    }

    .department-body {
        padding: 1.5rem;
    }

    .dept-stat {
        display: flex;
        justify-content: space-between;
        padding: 0.75rem 0;
        border-bottom: 1px solid var(--border-color);
    }

    .dept-stat:last-child {
        border-bottom: none;
    }

    .dept-stat label {
        color: var(--text-light);
        font-size: 0.9rem;
    }

    .dept-stat .value {
        font-weight: 700;
        color: var(--text-dark);
    }

    .dept-actions {
        display: flex;
        gap: 0.5rem;
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid var(--border-color);
    }

    .dept-actions button,
    .dept-actions a {
        flex: 1;
        padding: 0.5rem 0.75rem;
        font-size: 0.85rem;
    }

    .department-color-it {
        background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
    }

    .department-color-hr {
        background: linear-gradient(135deg, #10b981 0%, #059e0a 100%);
    }

    .department-color-finance {
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    }

    .department-color-operations {
        background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
    }

    .department-color-sales {
        background: linear-gradient(135deg, #ec4899 0%, #db2777 100%);
    }

    .department-color-marketing {
        background: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%);
    }

    .department-list-view {
        margin-top: 2rem;
    }

    .list-table {
        width: 100%;
    }

    .view-toggle {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
    }

    .view-toggle button {
        padding: 0.5rem 1rem;
        border: 1px solid var(--border-color);
        background: white;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .view-toggle button.active {
        background: var(--primary-color);
        color: white;
        border-color: var(--primary-color);
    }

    .employee-preview {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-top: 0.75rem;
        padding-top: 0.75rem;
        border-top: 1px solid var(--border-color);
    }

    .employee-preview small {
        color: var(--text-light);
    }
</style>

<div class="page-header">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <div>
            <h1 class="page-title">Departments Management</h1>
            <p class="page-subtitle">Manage all departments in your organization</p>
        </div>
        <a href="#" class="btn btn-primary">
            <i class="fas fa-plus"></i> Add Department
        </a>
    </div>
</div>

<!-- View Toggle -->
<div class="view-toggle">
    <button class="active" data-view="card">
        <i class="fas fa-th"></i> Card View
    </button>
    <button data-view="list">
        <i class="fas fa-list"></i> List View
    </button>
</div>

