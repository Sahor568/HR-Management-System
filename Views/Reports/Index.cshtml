@{
    ViewData["Title"] = "Reports & Analytics";
}

<style>
    .report-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .report-card {
        background: var(--white);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .report-card:hover {
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
        border-color: var(--primary-color);
        transform: translateY(-4px);
    }

    .report-icon {
        font-size: 2rem;
        margin-bottom: 0.5rem;
    }

    .report-title {
        font-weight: 600;
        margin: 0.5rem 0;
        color: var(--text-dark);
    }

    .report-desc {
        font-size: 0.85rem;
        color: var(--text-light);
        margin: 0;
    }

    .chart-container {
        background: var(--white);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 2rem;
        margin-bottom: 2rem;
    }

    .chart-title {
        font-size: 1.2rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
        color: var(--text-dark);
    }

    .simple-chart {
        width: 100%;
        height: 300px;
        background: var(--light-bg);
        border-radius: 8px;
        padding: 1rem;
    }

    .filter-section {
        background: var(--white);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 2rem;
    }

    .filter-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .report-action-buttons {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .table-responsive-custom {
        overflow-x: auto;
    }
</style>

<div class="page-header">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <div>
            <h1 class="page-title">Reports & Analytics</h1>
            <p class="page-subtitle">Generate and view comprehensive HR reports</p>
        </div>
        <div>
            <button class="btn btn-outline-primary" style="margin-right: 0.5rem;">
                <i class="fas fa-download"></i> Export
            </button>
            <button class="btn btn-primary">
                <i class="fas fa-plus"></i> Custom Report
            </button>
        </div>
    </div>
</div>

<!-- Report Categories -->
<div class="report-grid">
    <div class="report-card">
        <div class="report-icon" style="color: var(--primary-color);">
            <i class="fas fa-users"></i>
        </div>
        <h6 class="report-title">Employee Report</h6>
        <p class="report-desc">Employee details and statistics</p>
    </div>

    <div class="report-card">
        <div class="report-icon" style="color: var(--success-color);">
            <i class="fas fa-calendar-check"></i>
        </div>
        <h6 class="report-title">Attendance Report</h6>
        <p class="report-desc">Daily attendance records</p>
    </div>

    <div class="report-card">
        <div class="report-icon" style="color: var(--warning-color);">
            <i class="fas fa-calendar-alt"></i>
        </div>
        <h6 class="report-title">Leave Report</h6>
        <p class="report-desc">Leave requests and approvals</p>
    </div>

    <div class="report-card">
        <div class="report-icon" style="color: var(--danger-color);">
            <i class="fas fa-money-bill-wave"></i>
        </div>
        <h6 class="report-title">Payroll Report</h6>
        <p class="report-desc">Salary and payment details</p>
    </div>

    <div class="report-card">
        <div class="report-icon" style="color: #8b5cf6;">
            <i class="fas fa-chart-pie"></i>
        </div>
        <h6 class="report-title">Department Report</h6>
        <p class="report-desc">Department performance metrics</p>
    </div>

    <div class="report-card">
        <div class="report-icon" style="color: #06b6d4;">
            <i class="fas fa-file-pdf"></i>
        </div>
        <h6 class="report-title">Custom Report</h6>
        <p class="report-desc">Build your own report</p>
    </div>
</div>

<!-- Filters -->
<div class="filter-section">
    <h5 style="margin-top: 0;">Filter Options</h5>
    <div class="filter-row">
        <div>
            <label class="form-label">Date Range</label>
            <input type="date" class="form-control">
        </div>
        <div>
            <label class="form-label">Department</label>
            <select class="form-control">
                <option>All Departments</option>
                <option>IT</option>
                <option>HR</option>
                <option>Finance</option>
            </select>
        </div>
        <div>
            <label class="form-label">Employee</label>
            <select class="form-control">
                <option>All Employees</option>
                <option>John Doe</option>
                <option>Sarah Miller</option>
                <option>Mike Brown</option>
            </select>
        </div>
        <div>
            <label class="form-label">Report Type</label>
            <select class="form-control">
                <option>Summary</option>
                <option>Detailed</option>
                <option>Comparative</option>
            </select>
        </div>
    </div>
    <div class="report-action-buttons">
        <button class="btn btn-primary">
            <i class="fas fa-search"></i> Generate Report
        </button>
        <button class="btn btn-outline-primary">
            <i class="fas fa-download"></i> Download PDF
        </button>
        <button class="btn btn-outline-primary">
            <i class="fas fa-print"></i> Print
        </button>
        <button class="btn btn-outline-primary">
            <i class="fas fa-envelope"></i> Email
        </button>
    </div>
</div>

<!-- Employee Summary Chart -->
<div class="chart-container">
    <h5 class="chart-title">
        <i class="fas fa-chart-bar"></i> Employee Distribution by Department
    </h5>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
        <div>
            <div style="height: 300px; display: flex; align-items: flex-end; gap: 0.5rem;">
                <div style="flex: 1; background: linear-gradient(180deg, #2563eb 0%, #2563eb88 100%); height: 75%; border-radius: 6px;"></div>
                <div style="flex: 1; background: linear-gradient(180deg, #10b981 0%, #10b98188 100%); height: 50%; border-radius: 6px;"></div>
                <div style="flex: 1; background: linear-gradient(180deg, #f59e0b 0%, #f59e0b88 100%); height: 60%; border-radius: 6px;"></div>
                <div style="flex: 1; background: linear-gradient(180deg, #8b5cf6 0%, #8b5cf688 100%); height: 48%; border-radius: 6px;"></div>
                <div style="flex: 1; background: linear-gradient(180deg, #ec4899 0%, #ec489988 100%); height: 65%; border-radius: 6px;"></div>
            </div>
            <div style="display: flex; justify-content: space-around; margin-top: 1rem; font-size: 0.85rem;">
                <span><strong>IT</strong><br>28</span>
                <span><strong>HR</strong><br>15</span>
                <span><strong>Finance</strong><br>22</span>
                <span><strong>Operations</strong><br>18</span>
                <span><strong>Sales</strong><br>25</span>
            </div>
        </div>

        <div style="padding: 1rem; background: var(--light-bg); border-radius: 8px;">
            <h6 style="margin-top: 0;">Summary Statistics</h6>
            <div style="margin-bottom: 1rem;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                    <span>Total Employees</span>
                    <strong>156</strong>
                </div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                    <span>Total Departments</span>
                    <strong>8</strong>
                </div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                    <span>Avg Employees/Dept</span>
                    <strong>19.5</strong>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span>Total Payroll</span>
                    <strong>$485K/Month</strong>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Attendance Metrics -->
<div class="chart-container">
    <h5 class="chart-title">
        <i class="fas fa-chart-line"></i> Attendance Metrics (Last 30 Days)
    </h5>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem;">
        <div style="background: var(--light-bg); padding: 1rem; border-radius: 8px; text-align: center;">
            <div style="font-size: 1.5rem; font-weight: 700; color: var(--success-color);">87.4%</div>
            <div style="font-size: 0.9rem; color: var(--text-light); margin-top: 0.5rem;">Average Attendance</div>
        </div>
        <div style="background: var(--light-bg); padding: 1rem; border-radius: 8px; text-align: center;">
            <div style="font-size: 1.5rem; font-weight: 700; color: #f59e0b;">245</div>
            <div style="font-size: 0.9rem; color: var(--text-light); margin-top: 0.5rem;">Total Late Marks</div>
        </div>
        <div style="background: var(--light-bg); padding: 1rem; border-radius: 8px; text-align: center;">
            <div style="font-size: 1.5rem; font-weight: 700; color: var(--danger-color);">156</div>
            <div style="font-size: 0.9rem; color: var(--text-light); margin-top: 0.5rem;">Total Absents</div>
        </div>
        <div style="background: var(--light-bg); padding: 1rem; border-radius: 8px; text-align: center;">
            <div style="font-size: 1.5rem; font-weight: 700; color: var(--primary-color);">3,876</div>
            <div style="font-size: 0.9rem; color: var(--text-light); margin-top: 0.5rem;">Total Working Hours</div>
        </div>
    </div>
</div>

<!-- Leave Summary -->
<div class="card">
    <div class="card-header">
        <h5 style="margin: 0;">
            <i class="fas fa-calendar-alt"></i> Leave Summary Report
        </h5>
    </div>
    <div class="card-body">
        <div class="table-responsive-custom">
            <table class="table">
                <thead>
                    <tr>
                        <th>Leave Type</th>
                        <th>Requested</th>
                        <th>Approved</th>
                        <th>Pending</th>
                        <th>Rejected</th>
                        <th>Approval Rate</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>Vacation</strong></td>
                        <td>32</td>
                        <td>28</td>
                        <td>3</td>
                        <td>1</td>
                        <td>87.5%</td>
                    </tr>
                    <tr>
                        <td><strong>Sick Leave</strong></td>
                        <td>18</td>
                        <td>18</td>
                        <td>0</td>
                        <td>0</td>
                        <td>100%</td>
                    </tr>
                    <tr>
                        <td><strong>Personal</strong></td>
                        <td>12</td>
                        <td>10</td>
                        <td>2</td>
                        <td>0</td>
                        <td>83.3%</td>
                    </tr>
                    <tr>
                        <td><strong>Maternity</strong></td>
                        <td>3</td>
                        <td>3</td>
                        <td>0</td>
                        <td>0</td>
                        <td>100%</td>
                    </tr>
                    <tr style="background: var(--light-bg); font-weight: 600;">
                        <td>Total</td>
                        <td>65</td>
                        <td>59</td>
                        <td>5</td>
                        <td>1</td>
                        <td>90.8%</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
