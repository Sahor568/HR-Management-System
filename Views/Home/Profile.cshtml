@{
    ViewData["Title"] = "My Profile";
}

<div class="container-fluid">
    <div class="page-header">
        <h1 class="page-title"><i class="fas fa-user me-2"></i>My Profile</h1>
        <p class="page-subtitle">View your personal information</p>
    </div>
    
    <div class="row">
        <div class="col-lg-4">
            <div class="card">
                <div class="card-body text-center">
                    <div class="mb-4">
                        <div class="avatar-profile mx-auto">
                            <div class="avatar-initials" id="profile-initials">--</div>
                        </div>
                        <h4 class="mt-3 mb-0" id="profile-name">Loading...</h4>
                        <p class="text-muted" id="profile-role">-</p>
                    </div>
                    
                    <div class="list-group list-group-flush text-start">
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="fas fa-envelope me-2 text-primary"></i>Email</span>
                            <span class="text-muted" id="profile-email">-</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="fas fa-phone me-2 text-primary"></i>Phone</span>
                            <span class="text-muted" id="profile-phone">-</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="fas fa-building me-2 text-primary"></i>Department</span>
                            <span class="text-muted" id="profile-department">-</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="fas fa-user-tie me-2 text-primary"></i>Supervisor</span>
                            <span class="text-muted" id="profile-supervisor">-</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="fas fa-shield-alt me-2 text-primary"></i>Status</span>
                            <span class="badge bg-success">Active</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="card mt-4">
                <div class="card-header">
                    <h6 class="mb-0"><i class="fas fa-chart-line me-2"></i>Quick Stats</h6>
                </div>
                <div class="card-body" id="quick-stats-body">
                    <div class="text-center text-muted">
                        <div class="spinner-border spinner-border-sm" role="status"></div>
                        <span class="ms-2">Loading stats...</span>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <ul class="nav nav-tabs card-header-tabs">
                        <li class="nav-item">
                            <a class="nav-link active" data-bs-toggle="tab" href="#personal">Personal Info</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#employment">Employment</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#leaves">My Leaves</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#payroll">Payroll</a>
                        </li>
                    </ul>
                </div>
                <div class="card-body">
                    <div class="tab-content">
                        <!-- Personal Info Tab -->
                        <div class="tab-pane fade show active" id="personal">
                            <form id="personalInfoForm">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Full Name</label>
                                        <input type="text" class="form-control" id="edit-fullName" disabled>
                                        <div class="form-text">Contact HR to update your name.</div>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Email</label>
                                        <input type="email" class="form-control" id="edit-email" disabled>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Phone</label>
                                        <input type="tel" class="form-control" id="edit-phone" disabled>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Age</label>
                                        <input type="number" class="form-control" id="edit-age" disabled>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Address</label>
                                    <textarea class="form-control" rows="3" id="edit-address" disabled></textarea>
                                </div>
                                <div class="alert alert-info mb-0">
                                    <i class="fas fa-info-circle me-2"></i>
                                    To update your personal information, please go to <a href="/Home/Settings">Settings</a> or contact HR.
                                </div>
                            </form>
                        </div>
                        
                        <!-- Employment Tab -->
                        <div class="tab-pane fade" id="employment">
                            <div class="table-responsive">
                                <table class="table table-borderless">
                                    <tbody id="employment-details">
                                        <tr>
                                            <th width="30%">Employee ID</th>
                                            <td id="emp-id">-</td>
                                        </tr>
                                        <tr>
                                            <th>Department</th>
                                            <td id="emp-department">-</td>
                                        </tr>
                                        <tr>
                                            <th>Supervisor</th>
                                            <td id="emp-supervisor">-</td>
                                        </tr>
                                        <tr>
                                            <th>Salary</th>
                                            <td id="emp-salary">-</td>
                                        </tr>
                                        <tr>
                                            <th>Role</th>
                                            <td id="emp-role">-</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>
                                Employment details are managed by HR department. Contact HR for any changes.
                            </div>
                        </div>
                        
                        <!-- Leaves Tab -->
                        <div class="tab-pane fade" id="leaves">
                            <div id="my-leaves-container">
                                <div class="text-center text-muted py-4">
                                    <div class="spinner-border spinner-border-sm" role="status"></div>
                                    <span class="ms-2">Loading leaves...</span>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Payroll Tab -->
                        <div class="tab-pane fade" id="payroll">
                            <div id="my-payroll-container">
                                <div class="text-center text-muted py-4">
                                    <div class="spinner-border spinner-border-sm" role="status"></div>
                                    <span class="ms-2">Loading payroll...</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .avatar-profile {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
    }
    
    .avatar-initials {
        font-size: 2.5rem;
        font-weight: bold;
        color: white;
    }
</style>

@section Scripts {
    <script>
        let currentEmployeeId = null;
        let currentEmployeeData = null;

        document.addEventListener('DOMContentLoaded', async function() {
            await loadProfile();
            loadQuickStats();
        });

        async function loadProfile() {
            try {
                const data = await AuthAPI.getCurrentUser();
                
                // Update sidebar card
                const fullName = data.employee?.fullName || data.email || 'User';
                const role = data.role || 'Unknown';
                const initials = getInitials(fullName);

                document.getElementById('profile-initials').textContent = initials;
                document.getElementById('profile-name').textContent = fullName;
                document.getElementById('profile-role').textContent = role;
                document.getElementById('profile-email').textContent = data.email || '-';
                document.getElementById('profile-phone').textContent = data.employee?.phone || '-';
                document.getElementById('profile-department').textContent = data.employee?.departmentName || '-';
                document.getElementById('profile-supervisor').textContent = data.employee?.supervisorName || '-';

                // Employment tab
                document.getElementById('emp-id').textContent = data.employee?.id || '-';
                document.getElementById('emp-department').textContent = data.employee?.departmentName || '-';
                document.getElementById('emp-supervisor').textContent = data.employee?.supervisorName || '-';
                document.getElementById('emp-salary').textContent = data.employee?.salary ? formatCurrency(data.employee.salary) : '-';
                document.getElementById('emp-role').textContent = role;

                // Personal info form
                document.getElementById('edit-fullName').value = fullName;
                document.getElementById('edit-email').value = data.email || '';
                document.getElementById('edit-phone').value = data.employee?.phone || '';
                document.getElementById('edit-age').value = data.employee?.age || '';
                document.getElementById('edit-address').value = data.employee?.address || '';

                currentEmployeeId = data.employee?.id || null;
                currentEmployeeData = data;

                // Load leaves and payroll for the tabs
                if (currentEmployeeId) {
                    loadMyLeaves();
                    loadMyPayroll();
                }

            } catch (error) {
                console.error('Failed to load profile:', error);
                document.getElementById('profile-name').textContent = 'Error loading profile';
            }
        }

        async function loadQuickStats() {
            const statsBody = document.getElementById('quick-stats-body');
            try {
                // Load leave stats
                let leaveBalance = '-';
                let pendingLeaves = 0;
                let approvedLeaves = 0;
                try {
                    const leaves = await LeavesAPI.getMyLeaves();
                    if (Array.isArray(leaves)) {
                        pendingLeaves = leaves.filter(l => l.status === 'Pending').length;
                        approvedLeaves = leaves.filter(l => l.status === 'Approved').length;
                        const totalLeaves = leaves.length;
                        leaveBalance = Math.max(0, 20 - totalLeaves) + ' days';
                    }
                } catch (e) { /* ignore */ }

                // Load attendance stats
                let attendanceRate = '-';
                try {
                    const empId = currentEmployeeId;
                    if (empId) {
                        const attendance = await AttendanceAPI.getByEmployee(empId);
                        if (Array.isArray(attendance) && attendance.length > 0) {
                            const presentCount = attendance.filter(a => a.status === 'Present').length;
                            attendanceRate = Math.round((presentCount / attendance.length) * 100) + '%';
                        }
                    }
                } catch (e) { /* ignore */ }

                statsBody.innerHTML = `
                    <div class="d-flex justify-content-between mb-3">
                        <span>Leave Balance</span>
                        <strong>${leaveBalance}</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span>Pending Leaves</span>
                        <strong class="text-warning">${pendingLeaves}</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span>Approved Leaves</span>
                        <strong class="text-success">${approvedLeaves}</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Attendance Rate</span>
                        <strong>${attendanceRate}</strong>
                    </div>
                `;
            } catch (error) {
                statsBody.innerHTML = '<p class="text-muted text-center">Could not load stats</p>';
            }
        }

        async function loadMyLeaves() {
            const container = document.getElementById('my-leaves-container');
            try {
                const leaves = await LeavesAPI.getMyLeaves();
                if (!Array.isArray(leaves) || leaves.length === 0) {
                    container.innerHTML = `
                        <div class="text-center text-muted py-4">
                            <i class="fas fa-calendar-check fa-2x mb-2"></i>
                            <p>No leave records found.</p>
                        </div>
                    `;
                    return;
                }

                let html = `
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>From</th>
                                    <th>To</th>
                                    <th>Days</th>
                                    <th>Reason</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                `;

                leaves.forEach(leave => {
                    const fromDate = new Date(leave.fromDate);
                    const toDate = new Date(leave.toDate);
                    const days = Math.ceil((toDate - fromDate) / (1000 * 60 * 60 * 24)) + 1;
                    html += `
                        <tr>
                            <td>${leave.leaveType || 'General'}</td>
                            <td>${formatDate(leave.fromDate)}</td>
                            <td>${formatDate(leave.toDate)}</td>
                            <td>${days}</td>
                            <td>${leave.reason || '-'}</td>
                            <td><span class="badge ${getStatusBadgeClass(leave.status)}">${leave.status}</span></td>
                        </tr>
                    `;
                });

                html += '</tbody></table></div>';
                container.innerHTML = html;
            } catch (error) {
                container.innerHTML = '<p class="text-danger text-center">Failed to load leave records.</p>';
            }
        }

        async function loadMyPayroll() {
            const container = document.getElementById('my-payroll-container');
            try {
                const payrolls = await PayrollAPI.getByEmployee(currentEmployeeId);
                if (!Array.isArray(payrolls) || payrolls.length === 0) {
                    container.innerHTML = `
                        <div class="text-center text-muted py-4">
                            <i class="fas fa-money-bill-wave fa-2x mb-2"></i>
                            <p>No payroll records found.</p>
                        </div>
                    `;
                    return;
                }

                let html = `
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Month/Year</th>
                                    <th>Basic Salary</th>
                                    <th>Bonus</th>
                                    <th>Deductions</th>
                                    <th>Net Pay</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                `;

                payrolls.forEach(p => {
                    const netPay = (p.basicSalary || 0) + (p.bonus || 0) - (p.deductions || 0);
                    const monthYear = (p.month || '-') + '/' + (p.year || '-');
                    const status = p.approvalStatus || p.status || 'Pending';
                    html += `
                        <tr>
                            <td>${monthYear}</td>
                            <td>${formatCurrency(p.basicSalary || 0)}</td>
                            <td>${formatCurrency(p.bonus || 0)}</td>
                            <td>${formatCurrency(p.deductions || 0)}</td>
                            <td><strong>${formatCurrency(netPay)}</strong></td>
                            <td><span class="badge ${getStatusBadgeClass(status)}">${status}</span></td>
                        </tr>
                    `;
                });

                html += '</tbody></table></div>';
                container.innerHTML = html;
            } catch (error) {
                container.innerHTML = '<p class="text-danger text-center">Failed to load payroll records.</p>';
            }
        }

        function downloadPayslip(payrollId) {
            // Payslip download feature - not yet implemented
            showNotification('Info', 'Payslip download is not available yet. Contact HR for a copy.', 'info');
        }
    </script>
}
