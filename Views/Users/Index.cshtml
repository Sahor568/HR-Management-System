                <button class="btn btn-sm btn-outline-danger w-100">Deactivate</button>
            </div>
        </div>

        <div class="user-card">
            <div class="user-card-avatar" style="background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);">JD</div>
            <h5>John Doe</h5>
            <p>john@company.com</p>
            <div style="margin: 1rem 0;">
                <span class="role-badge role-employee">Employee</span>
            </div>
            <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
                <a href="#" class="btn btn-sm btn-outline-primary w-100">Edit</a>
                <button class="btn btn-sm btn-outline-danger w-100">Deactivate</button>
            </div>
        </div>

        <div class="user-card">
            <div class="user-card-avatar" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);">MB</div>
            <h5>Mike Brown</h5>
            <p>mike@company.com</p>
            <div style="margin: 1rem 0;">
                <span class="role-badge role-employee">Employee</span>
