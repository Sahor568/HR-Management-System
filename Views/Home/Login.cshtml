@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0"><i class="fas fa-sign-in-alt me-2"></i>Login to HR System</h4>
                </div>
                <div class="card-body p-4">
                    <div id="loginError" class="alert alert-danger d-none alert-dismissible fade show">
                        <strong>Error!</strong> <span id="loginErrorMsg"></span>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>

                    <form id="loginForm">
                        <div class="mb-3">
                            <label for="email" class="form-label">Email Address</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                <input type="email" class="form-control" id="email" name="email" placeholder="Enter your email" required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="password" class="form-label">Password</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-lock"></i></span>
                                <input type="password" class="form-control" id="password" name="password" placeholder="Enter your password" required>
                            </div>
                        </div>
                        <div class="mb-3 form-check">
                            <input type="checkbox" class="form-check-input" id="rememberMe" name="rememberMe">
                            <label class="form-check-label" for="rememberMe">Remember me</label>
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg" id="loginBtn">
                                <i class="fas fa-sign-in-alt me-2"></i>Login
                            </button>
                        </div>
                    </form>
                    <div class="mt-4 text-center">
                        <p class="text-muted mb-0">Demo Credentials:</p>
                        <p class="mb-0"><small>Admin: admin@hrsystem.com / Admin@123</small></p>
                        <p class="mb-0"><small>HR: hr@hrsystem.com / Hr@123</small></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('loginForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const email = document.getElementById('email').value.trim();
            const password = document.getElementById('password').value;
            const loginBtn = document.getElementById('loginBtn');
            const errorDiv = document.getElementById('loginError');
            const errorMsg = document.getElementById('loginErrorMsg');

            // Reset error
            errorDiv.classList.add('d-none');

            // Disable button
            loginBtn.disabled = true;
            loginBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Signing in...';

            try {
                // Step 1: Call API to get JWT token
                const apiResponse = await fetch('/api/Login/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password })
                });

                if (!apiResponse.ok) {
                    const errorData = await apiResponse.json().catch(() => ({ message: 'Invalid credentials' }));
                    throw new Error(errorData.message || 'Invalid email or password');
                }

                const data = await apiResponse.json();

                // Step 2: Store JWT token and user info in localStorage
                localStorage.setItem('auth_token', data.token);
                localStorage.setItem('user_email', email);
                localStorage.setItem('user_role', data.role || '');
                localStorage.setItem('user_id', data.id || '');
                localStorage.setItem('user_name', data.fullName || email);

                // Step 3: Also create cookie auth by posting to MVC Login action
                try {
                    const formData = new FormData();
                    formData.append('email', email);
                    formData.append('password', password);

                    await fetch('/Home/Login', {
                        method: 'POST',
                        body: formData,
                        credentials: 'include'
                    });
                } catch (cookieErr) {
                    console.warn('Cookie auth setup failed (non-critical):', cookieErr);
                }

                // Step 4: Fetch employee profile to get employeeId and fullName
                try {
                    const profileResponse = await fetch('/api/Employees/my-profile', {
                        headers: { 'Authorization': 'Bearer ' + data.token }
                    });
                    if (profileResponse.ok) {
                        const profile = await profileResponse.json();
                        if (profile.id) {
                            localStorage.setItem('user_employeeId', profile.id);
                        }
                        if (profile.fullName) {
                            localStorage.setItem('user_name', profile.fullName);
                        }
                    }
                } catch (profileErr) {
                    console.warn('Could not fetch employee profile:', profileErr);
                }

                // Step 5: Redirect to Dashboard
                window.location.href = '/Home/Dashboard';

            } catch (error) {
                errorMsg.textContent = error.message || 'Login failed. Please try again.';
                errorDiv.classList.remove('d-none');
                loginBtn.disabled = false;
                loginBtn.innerHTML = '<i class="fas fa-sign-in-alt me-2"></i>Login';
            }
        });
    </script>
}
