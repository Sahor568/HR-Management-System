@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .chart-container {
        background: var(--white);
        border-radius: 12px;
        padding: 1.5rem;
        border: 1px solid var(--border-color);
        margin-bottom: 2rem;
    }

    .chart-title {
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 1rem;
        color: var(--text-dark);
    }

    .stat-change {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 0.5rem;
    }

    .stat-change.positive { color: var(--success-color); }
    .stat-change.negative { color: var(--danger-color); }

    .row-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
    }

    .progress-bar-custom {
        width: 100%;
        height: 8px;
        background: var(--light-bg);
        border-radius: 4px;
        overflow: hidden;
    }

    .progress-fill {
        height: 100%;
        border-radius: 4px;
        transition: width 0.5s ease;
    }

    .bar-chart {
        display: flex;
        align-items: flex-end;
        gap: 0.5rem;
        height: 200px;
        padding-bottom: 30px;
        position: relative;
    }

    .bar-item {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        height: 100%;
        justify-content: flex-end;
    }

    .bar-fill {
        width: 100%;
        max-width: 50px;
        background: linear-gradient(180deg, #2563eb 0%, #2563eb88 100%);
        border-radius: 6px 6px 0 0;
        min-height: 4px;
        transition: height 0.5s ease;
    }

    .bar-label {
        font-size: 0.75rem;
        color: var(--text-light);
        margin-top: 8px;
        position: absolute;
        bottom: 0;
    }

    .activity-item {
        display: flex;
        gap: 1rem;
        padding: 1rem 0;
        border-bottom: 1px solid var(--border-color);
    }

    .activity-item:last-child {
        border-bottom: none;
    }

    .activity-icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
</style>

<div class="page-header">
    <h1 class="page-title">Dashboard</h1>
    <p class="page-subtitle">Welcome to HR Management System - Overview of your organization</p>
</div>

<!-- Key Metrics -->
<div class="dashboard-grid" id="dashboard-stats">
    <div class="kpi-card">
        <div class="kpi-icon" style="background: linear-gradient(135deg, #2563eb15 0%, #0ea5e915 100%); color: var(--primary-color);">
            <i class="fas fa-users"></i>
        </div>
        <h5 class="kpi-label">Total Employees</h5>
        <div class="kpi-value" id="total-employees">--</div>
        <div class="stat-change positive" id="employee-change">
            <i class="fas fa-users"></i> Active workforce
        </div>
    </div>

    <div class="kpi-card">
        <div class="kpi-icon" style="background: linear-gradient(135deg, #10b98115 0%, #059e0a15 100%); color: var(--success-color);">
            <i class="fas fa-check-circle"></i>
        </div>
        <h5 class="kpi-label">Present Today</h5>
        <div class="kpi-value" id="present-today">--</div>
        <div class="stat-change positive" id="attendance-percent">
            <i class="fas fa-arrow-up"></i> --% attendance
        </div>
    </div>

    <div class="kpi-card">
        <div class="kpi-icon" style="background: linear-gradient(135deg, #f59e0b15 0%, #d9790015 100%); color: var(--warning-color);">
            <i class="fas fa-calendar-alt"></i>
        </div>
        <h5 class="kpi-label">Pending Leaves</h5>
        <div class="kpi-value" id="pending-leaves">--</div>
        <div class="stat-change negative" id="leaves-change">
            <i class="fas fa-clock"></i> Awaiting approval
        </div>
    </div>

    <div class="kpi-card" id="payroll-card">
        <div class="kpi-icon" style="background: linear-gradient(135deg, #ef444415 0%, #dc263015 100%); color: var(--danger-color);">
            <i class="fas fa-money-bill-wave"></i>
        </div>
        <h5 class="kpi-label">Monthly Payroll</h5>
        <div class="kpi-value" id="monthly-payroll">--</div>
        <div class="stat-change" id="payroll-period">
            <i class="fas fa-calendar"></i> Current Month
        </div>
    </div>

    <div class="kpi-card">
        <div class="kpi-icon" style="background: linear-gradient(135deg, #8b5cf615 0%, #7c3aed15 100%); color: #7c3aed;">
            <i class="fas fa-sitemap"></i>
        </div>
        <h5 class="kpi-label">Departments</h5>
        <div class="kpi-value" id="total-departments">--</div>
        <div class="stat-change">
            <i class="fas fa-building"></i> Active
        </div>
    </div>

    <div class="kpi-card" id="avg-salary-card">
        <div class="kpi-icon" style="background: linear-gradient(135deg, #06b6d415 0%, #0891b215 100%); color: #0891b2;">
            <i class="fas fa-chart-pie"></i>
        </div>
        <h5 class="kpi-label">Avg. Salary</h5>
        <div class="kpi-value" id="avg-salary">--</div>
        <div class="stat-change">
            <i class="fas fa-arrow-right"></i> Per Employee
        </div>
    </div>
</div>

<!-- Charts Section -->
<div class="row-cards">
    <!-- Attendance Trend Chart -->
    <div class="chart-container">
        <h5 class="chart-title">
            <i class="fas fa-chart-line"></i> Attendance Trend (Last 7 Days)
        </h5>
        <div class="bar-chart" id="attendance-chart">
            <div class="text-center text-muted w-100">Loading...</div>
        </div>
        <div style="margin-top: 10px; padding-top: 1rem; border-top: 1px solid var(--border-color);">
            <small class="text-muted" id="avg-attendance-text">Average attendance: --</small>
        </div>
    </div>

    <!-- Leave Status -->
    <div class="chart-container">
        <h5 class="chart-title">
            <i class="fas fa-calendar-check"></i> Leave Status
        </h5>
        <div style="padding: 1rem;" id="leave-status-container">
            <div class="text-center text-muted">Loading...</div>
        </div>
    </div>

    <!-- Employee Distribution -->
    <div class="chart-container">
        <h5 class="chart-title">
            <i class="fas fa-users"></i> Department Distribution
        </h5>
        <div id="dept-distribution-container">
            <div class="text-center text-muted">Loading...</div>
        </div>
    </div>
</div>

<!-- Recent Activities -->
<div class="card" style="margin-top: 2rem;">
    <div class="card-header">
        <h5 style="margin: 0;">
            <i class="fas fa-clock"></i> Recent Activities
        </h5>
    </div>
    <div class="card-body">
        <div style="max-height: 300px; overflow-y: auto;" id="recent-activities">
            <div class="text-center text-muted">Loading...</div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div style="margin-top: 2rem; display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;" id="quick-actions">
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', async function() {
            const role = getUserRole();
            const isAdminOrHRUser = isAdminOrHR();

            // Load Dashboard Stats
            try {
                const stats = await DashboardAPI.getStats();
                
                if (stats.totalEmployees !== undefined) {
                    document.getElementById('total-employees').textContent = stats.totalEmployees;
                }
                if (stats.presentToday !== undefined) {
                    document.getElementById('present-today').textContent = stats.presentToday;
                    const totalEmployees = stats.totalEmployees || 1;
                    const attendancePercent = totalEmployees > 0
                        ? Math.round((stats.presentToday / totalEmployees) * 100)
                        : 0;
                    document.getElementById('attendance-percent').innerHTML =
                        `<i class="fas fa-arrow-up"></i> ${attendancePercent}% attendance`;
                }
                if (stats.pendingLeaves !== undefined) {
                    document.getElementById('pending-leaves').textContent = stats.pendingLeaves;
                }
                if (stats.totalPayroll !== undefined) {
                    const formatted = formatCurrency(stats.totalPayroll);
                    document.getElementById('monthly-payroll').textContent = formatted;
                } else {
                    // Employee can't see payroll
                    document.getElementById('payroll-card').style.display = 'none';
                    document.getElementById('avg-salary-card').style.display = 'none';
                }
                if (stats.totalDepartments !== undefined) {
                    document.getElementById('total-departments').textContent = stats.totalDepartments;
                }
                if (stats.totalPayroll !== undefined && stats.totalEmployees !== undefined && stats.totalEmployees > 0) {
                    const avgSalary = Math.round(stats.totalPayroll / stats.totalEmployees);
                    document.getElementById('avg-salary').textContent = formatCurrency(avgSalary);
                }
            } catch (error) {
                console.error('Failed to load dashboard stats:', error);
            }

            // Load Attendance Trend
            try {
                const trend = await DashboardAPI.getAttendanceTrend(7);
                const chartEl = document.getElementById('attendance-chart');
                if (trend && Array.isArray(trend) && trend.length > 0) {
                    const maxCount = Math.max(...trend.map(t => t.presentCount || 0), 1);
                    let totalPercent = 0;
                    chartEl.innerHTML = trend.map(t => {
                        const height = maxCount > 0 ? Math.max((t.presentCount / maxCount) * 100, 4) : 4;
                        const dayName = new Date(t.date).toLocaleDateString('en-US', { weekday: 'short' });
                        const percent = t.totalEmployees > 0 ? Math.round((t.presentCount / t.totalEmployees) * 100) : 0;
                        totalPercent += percent;
                        return `
                            <div class="bar-item">
                                <div class="bar-fill" style="height: ${height}%;" title="${dayName}: ${t.presentCount}/${t.totalEmployees} (${percent}%)"></div>
                                <span class="bar-label">${dayName}</span>
                            </div>
                        `;
                    }).join('');
                    const avgPercent = Math.round(totalPercent / trend.length);
                    document.getElementById('avg-attendance-text').textContent = `Average attendance: ${avgPercent}%`;
                } else {
                    chartEl.innerHTML = '<div class="text-center text-muted w-100">No attendance data available</div>';
                }
            } catch (error) {
                console.error('Failed to load attendance trend:', error);
                document.getElementById('attendance-chart').innerHTML = '<div class="text-center text-muted w-100">Failed to load data</div>';
            }

            // Load Leave Summary
            try {
                const leaveSummary = await DashboardAPI.getLeaveSummary();
                const container = document.getElementById('leave-status-container');
                if (leaveSummary) {
                    const approved = leaveSummary.approved || 0;
                    const pending = leaveSummary.pending || 0;
                    const rejected = leaveSummary.rejected || 0;
                    const total = approved + pending + rejected;
                    
                    container.innerHTML = `
                        <div style="margin-bottom: 1.5rem;">
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                <span style="font-size: 0.9rem; color: var(--text-light);">Approved</span>
                                <strong>${approved}</strong>
                            </div>
                            <div class="progress-bar-custom">
                                <div class="progress-fill" style="width: ${total > 0 ? (approved/total*100) : 0}%; background: var(--success-color);"></div>
                            </div>
                        </div>
                        <div style="margin-bottom: 1.5rem;">
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                <span style="font-size: 0.9rem; color: var(--text-light);">Pending</span>
                                <strong>${pending}</strong>
                            </div>
                            <div class="progress-bar-custom">
                                <div class="progress-fill" style="width: ${total > 0 ? (pending/total*100) : 0}%; background: var(--warning-color);"></div>
                            </div>
                        </div>
                        <div>
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                <span style="font-size: 0.9rem; color: var(--text-light);">Rejected</span>
                                <strong>${rejected}</strong>
                            </div>
                            <div class="progress-bar-custom">
                                <div class="progress-fill" style="width: ${total > 0 ? (rejected/total*100) : 0}%; background: var(--danger-color);"></div>
                            </div>
                        </div>
                    `;
                }
            } catch (error) {
                console.error('Failed to load leave summary:', error);
                document.getElementById('leave-status-container').innerHTML = '<div class="text-center text-muted">Failed to load data</div>';
            }

            // Load Department Distribution
            try {
                const distribution = await DashboardAPI.getEmployeeDistribution();
                const container = document.getElementById('dept-distribution-container');
                if (distribution && Array.isArray(distribution) && distribution.length > 0) {
                    const colors = ['var(--primary-color)', 'var(--success-color)', 'var(--warning-color)', '#7c3aed', '#0891b2', '#ef4444'];
                    container.innerHTML = `<table style="width: 100%; font-size: 0.9rem;">
                        ${distribution.map((d, i) => `
                            <tr style="border-bottom: 1px solid var(--border-color); padding: 0.5rem 0;">
                                <td style="padding: 0.75rem 0;">${d.departmentName || d.name || 'Unknown'}</td>
                                <td style="text-align: right; font-weight: 600; color: ${colors[i % colors.length]};">${d.employeeCount || d.count || 0}</td>
                            </tr>
                        `).join('')}
                    </table>`;
                } else {
                    container.innerHTML = '<div class="text-center text-muted">No department data available</div>';
                }
            } catch (error) {
                console.error('Failed to load department distribution:', error);
                document.getElementById('dept-distribution-container').innerHTML = '<div class="text-center text-muted">Failed to load data</div>';
            }

            // Load Recent Activities (from notifications)
            try {
                const notifResponse = await NotificationsAPI.getAll();
                const notifications = notifResponse.notifications || notifResponse;
                const container = document.getElementById('recent-activities');
                if (notifications && Array.isArray(notifications) && notifications.length > 0) {
                    const recent = notifications.slice(0, 5);
                    container.innerHTML = recent.map(n => {
                        const iconBg = n.notificationType === 'Leave' ? '#10b98115' : 
                                       n.notificationType === 'Payroll' ? '#f59e0b15' : 
                                       n.notificationType === 'Employee' ? '#2563eb15' : '#ef444415';
                        const iconColor = n.notificationType === 'Leave' ? 'var(--success-color)' : 
                                          n.notificationType === 'Payroll' ? 'var(--warning-color)' : 
                                          n.notificationType === 'Employee' ? 'var(--primary-color)' : 'var(--danger-color)';
                        const icon = n.notificationType === 'Leave' ? 'fa-calendar-check' : 
                                     n.notificationType === 'Payroll' ? 'fa-money-bill' : 
                                     n.notificationType === 'Employee' ? 'fa-user-plus' : 'fa-bell';
                        return `
                            <div class="activity-item">
                                <div class="activity-icon" style="background: ${iconBg}; color: ${iconColor};">
                                    <i class="fas ${icon}"></i>
                                </div>
                                <div style="flex: 1;">
                                    <p style="margin: 0; font-weight: 600; color: var(--text-dark);">${n.title || 'Notification'}</p>
                                    <small style="color: var(--text-light);">${n.message || ''}</small>
                                    <br>
                                    <small style="color: var(--text-light);">${n.createdAt ? formatDate(n.createdAt) : ''}</small>
                                </div>
                            </div>
                        `;
                    }).join('');
                } else {
                    container.innerHTML = '<div class="text-center text-muted py-3">No recent activities</div>';
                }
            } catch (error) {
                console.error('Failed to load recent activities:', error);
                document.getElementById('recent-activities').innerHTML = '<div class="text-center text-muted py-3">Failed to load activities</div>';
            }

            // Quick Actions based on role
            const actionsContainer = document.getElementById('quick-actions');
            let actions = '';
            if (isAdminOrHRUser) {
                actions += '<a href="/Employees" class="btn btn-primary w-100"><i class="fas fa-plus"></i> Add Employee</a>';
                actions += '<a href="/Leaves" class="btn btn-outline-primary w-100"><i class="fas fa-calendar"></i> Manage Leaves</a>';
                actions += '<a href="/Payrolls" class="btn btn-outline-primary w-100"><i class="fas fa-money-bill"></i> Payroll</a>';
            }
            actions += '<a href="/Attendances" class="btn btn-outline-primary w-100"><i class="fas fa-clock"></i> Attendance</a>';
            actions += '<a href="/Home/Settings" class="btn btn-outline-primary w-100"><i class="fas fa-cog"></i> Settings</a>';
            actionsContainer.innerHTML = actions;
        });
    </script>
}
